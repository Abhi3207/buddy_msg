# ============================================================================
# Messaging System — Environment Variables
# ============================================================================
# Copy this file to .env and adjust values for your environment.
# The server loads .env automatically via dotenv on startup.
# All variables have sensible defaults for local development.
# ============================================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- JWT Authentication ---
# IMPORTANT: Change this to a strong, random secret in production!
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# --- Database (SQLite) ---
DB_PATH=./data/messaging.db

# --- Cache ---
CACHE_MAX_SIZE=1000
CACHE_DEFAULT_TTL=300

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Message Queue ---
MQ_MAX_RETRIES=3
MQ_RETRY_DELAY=1000
MQ_MAX_SIZE=10000
MQ_PROCESSING_INTERVAL=100

# --- Logging ---
LOG_LEVEL=info
# LOG_DIR=./logs

# --- Bcrypt ---
BCRYPT_SALT_ROUNDS=10
